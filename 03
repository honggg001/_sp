3. game.js
JavaScript
const canvas = document.getElementById('gameCanvas');
const ctx = canvas.getContext('2d');
const scoreEl = document.getElementById('score');
const highScoreEl = document.getElementById('high-score');
const gameOverScreen = document.getElementById('game-over-screen');

// 遊戲狀態
let isPlaying = true;
let score = 0;
let highScore = 0;
let gameSpeed = 6;

// 摩托車（主角）屬性
const moto = {
    x: 50,
    y: 200,
    width: 60,
    height: 40,
    vy: 0,
    gravity: 0.6,
    jumpForce: -12,
    isGrounded: false,
    
    // 繪製帥氣的幾何摩托車
    draw() {
        ctx.save();
        // 車身顏色
        ctx.fillStyle = '#ff3333'; 
        // 車體主幹
        ctx.fillRect(this.x + 10, this.y + 10, 40, 15);
        // 車頭
        ctx.fillStyle = '#333';
        ctx.fillRect(this.x + 45, this.y, 8, 20);
        
        // 後輪
        ctx.beginPath();
        ctx.arc(this.x + 10, this.y + 30, 10, 0, Math.PI * 2);
        ctx.fillStyle = '#333';
        ctx.fill();
        ctx.lineWidth = 2;
        ctx.strokeStyle = '#fff';
        ctx.stroke();
        
        // 前輪
        ctx.beginPath();
        ctx.arc(this.x + 45, this.y + 30, 10, 0, Math.PI * 2);
        ctx.fillStyle = '#333';
        ctx.fill();
        ctx.stroke();

        // 騎士安全帽（簡單裝飾）
        ctx.beginPath();
        ctx.arc(this.x + 25, this.y, 8, 0, Math.PI * 2);
        ctx.fillStyle = '#000';
        ctx.fill();

        ctx.restore();
    },
    
    update() {
        // 重力影響
        this.vy += this.gravity;
        this.y += this.vy;
        
        // 地面碰撞偵測 (畫布高度 300 - 地面高度 40 = 260)
        const groundY = canvas.height - this.height - 20;
        if (this.y >= groundY) {
            this.y = groundY;
            this.vy = 0;
            this.isGrounded = true;
        } else {
            this.isGrounded = false;
        }
    },
    
    jump() {
        if (this.isGrounded) {
            this.vy = this.jumpForce;
        }
    }
};

// 障礙物類別
class Obstacle {
    constructor() {
        this.x = canvas.width;
        this.width = 20 + Math.random() * 20; // 隨機寬度
        this.height = 30 + Math.random() * 30; // 隨機高度
        this.y = canvas.height - this.height - 20;
    }
    
    draw() {
        ctx.fillStyle = '#555555'; // 障礙物顏色
        ctx.fillRect(this.x, this.y, this.width, this.height);
    }
    
    update() {
        this.x -= gameSpeed;
    }
}

let obstacles = [];
let spawnTimer = 0;

// 監聽鍵盤事件
window.addEventListener('keydown', (e) => {
    if (e.code === 'Space' || e.code === 'ArrowUp') {
        e.preventDefault(); // 防止網頁捲動
        if (isPlaying) {
            moto.jump();
        } else {
            resetGame();
        }
    }
});

// 碰撞偵測 AABB
function checkCollision(rect1, rect2) {
    return rect1.x < rect2.x + rect2.width &&
           rect1.x + rect1.width > rect2.x &&
           rect1.y < rect2.y + rect2.height &&
           rect1.y + rect1.height > rect2.y;
}

// 數字補零格式化 (e.g., 00123)
function formatScore(num) {
    return String(num).padStart(5, '0');
}

// 遊戲重置
function resetGame() {
    isPlaying = true;
    score = 0;
    gameSpeed = 6;
    obstacles = [];
    moto.y = 200;
    moto.vy = 0;
    gameOverScreen.classList.add('hidden');
    animate();
}

// 遊戲主迴圈
function animate() {
    if (!isPlaying) return;
    
    // 1. 清空畫布
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    
    // 2. 繪製地面線
    ctx.beginPath();
    ctx.moveTo(0, canvas.height - 20);
    ctx.lineTo(canvas.width, canvas.height - 20);
    ctx.strokeStyle = '#555';
    ctx.lineWidth = 2;
    ctx.stroke();
    
    // 3. 更新與繪製摩托車
    moto.update();
    moto.draw();
    
    // 4. 處理障礙物生成與移動
    spawnTimer++;
    // 隨機間隔生成障礙物
    if (spawnTimer > 80 + Math.random() * 60) {
        obstacles.push(new Obstacle());
        spawnTimer = 0;
    }
    
    for (let i = obstacles.length - 1; i >= 0; i--) {
        obstacles[i].update();
        obstacles[i].draw();
        
        // 碰撞偵測
        if (checkCollision(moto, obstacles[i])) {
            isPlaying = false;
            if (score > highScore) {
                highScore = score;
                highScoreEl.innerText = `HIGH: ${formatScore(highScore)}`;
            }
            gameOverScreen.classList.remove('hidden');
        }
        
        // 移除超出螢幕的障礙物
        if (obstacles[i].x + obstacles[i].width < 0) {
            obstacles.splice(i, 1);
        }
    }
    
    // 5. 計分與難度提升
    score++;
    scoreEl.innerText = `SCORE: ${formatScore(score)}`;
    
    if (score % 500 === 0) {
        gameSpeed += 0.8; // 每過 500 分加速
    }
    
    requestAnimationFrame(animate);
}

// 啟動遊戲
animate();